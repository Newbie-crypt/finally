# FinAlly environment variables.
# Copy this file to `.env` in the project root and fill in your keys:
#   cp .env.example .env
# `.env` is gitignored — never commit real keys.

# Required: OpenRouter API key for LLM chat functionality.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data.
# If not set (or empty), the built-in market simulator is used — recommended
# for most users, and the default experience.
MASSIVE_API_KEY=

# Optional: set to "true" for deterministic mock LLM responses (E2E tests,
# development without an API key). Leave "false" for normal use.
LLM_MOCK=false
